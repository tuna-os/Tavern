{
    "app-id": "dev.hanthor.Tavern.Devel",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "command": "tavern",
    "tags": ["devel"],
    "desktop-file-name-suffix": " (Devel)",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--share=network",
        "--talk-name=org.freedesktop.Flatpak",
        "--filesystem=home",
        "--filesystem=/home/linuxbrew:ro",
        "--env=HOMEBREW_NO_AUTO_UPDATE=1",
        "--own-name=dev.hanthor.Tavern.Devel.SearchProvider"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "blueprint-compiler",
            "buildsystem": "meson",
            "cleanup": ["*"],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/GNOME/blueprint-compiler.git",
                    "tag": "v0.16.0"
                }
            ]
        },
        {
            "name": "python3-markdown",
            "buildsystem": "simple",
            "build-commands": [
                "pip3 install --prefix=/app markdown"
            ],
            "sources": [
                {
                    "type": "inline",
                    "contents": "",
                    "dest-filename": "dummy"
                }
            ]
        },
        {
            "name": "tavern",
            "buildsystem": "meson",
            "config-opts": [
                "-Dprofile=development"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": "."
                }
            ]
        }
    ]
}
