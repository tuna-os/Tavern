#!/usr/bin/env python3
# tavern - Homebrew App Store for GNOME
# SPDX-License-Identifier: GPL-3.0-or-later

import os
import sys
import signal
import locale
import gettext

VERSION = '@VERSION@'
pkgdatadir = os.environ.get('TAVERN_DATADIR', '@PKGDATADIR@')
localedir = os.environ.get('TAVERN_LOCALEDIR', '@localedir@')

# Resolve absolute paths if they are relative to the executable (for portable macOS bundles)
if not pkgdatadir.startswith('/'):
    pkgdatadir = os.path.join(os.path.dirname(os.path.abspath(sys.argv[0])), pkgdatadir)
if not localedir.startswith('/'):
    localedir = os.path.join(os.path.dirname(os.path.abspath(sys.argv[0])), localedir)

sys.path.insert(1, pkgdatadir)
signal.signal(signal.SIGINT, signal.SIG_DFL)

try:
    locale.bindtextdomain('tavern', localedir)
    locale.textdomain('tavern')
except AttributeError:
    pass
gettext.install('tavern', localedir)

if __name__ == '__main__':
    import gi
    gi.require_version('Gtk', '4.0')
    gi.require_version('Adw', '1')

    from gi.repository import Gio
    resource = Gio.Resource.load(os.path.join(pkgdatadir, 'tavern.gresource'))
    resource._register()

    from tavern.main import main
    sys.exit(main(VERSION, '@APPLICATION_ID@'))
