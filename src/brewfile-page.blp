using Gtk 4.0;
using Adw 1;

template $TavernBrewfilePage: Adw.Bin {
  child: Box {
    orientation: vertical;

    Stack brewfile_stack {
      vexpand: true;
      transition-type: crossfade;

      StackPage {
        name: "loading";

        child: Box {
          orientation: vertical;
          valign: center;
          halign: center;
          spacing: 12;

          Spinner {
            width-request: 32;
            height-request: 32;
          }

          Label {
            label: "Loading Brewfile packages…";

            styles ["dim-label"]
          }
        };
      }

      StackPage {
        name: "content";

        child: ScrolledWindow {
          hscrollbar-policy: never;
          vexpand: true;

          child: Adw.Clamp {
            maximum-size: 1200;
            tightening-threshold: 1100;

            child: Box content_box {
              orientation: vertical;
              spacing: 16;
              margin-start: 20;
              margin-end: 20;
              margin-top: 12;
              margin-bottom: 40;

              /* Taps Section */
              Box taps_section {
                orientation: vertical;
                spacing: 8;
                visible: false;

                Label {
                  label: "Taps";
                  xalign: 0.0;
                  margin-start: 4;

                  styles ["title-3"]
                }

                FlowBox taps_flow {
                  selection-mode: none;
                  column-spacing: 8;
                  row-spacing: 8;
                  homogeneous: false;
                }
              }

              /* Formulae Section */
              Box formulae_section {
                orientation: vertical;
                spacing: 8;
                visible: false;

                Label {
                  label: "Formulae";
                  xalign: 0.0;
                  margin-start: 4;

                  styles ["title-2"]
                }

                FlowBox formulae_flow {
                  selection-mode: none;
                  homogeneous: true;
                  column-spacing: 8;
                  row-spacing: 8;
                  min-children-per-line: 2;
                  max-children-per-line: 4;
                }
              }

              /* Casks Section */
              Box casks_section {
                orientation: vertical;
                spacing: 8;
                visible: false;

                Label {
                  label: "Casks";
                  xalign: 0.0;
                  margin-start: 4;

                  styles ["title-2"]
                }

                FlowBox casks_flow {
                  selection-mode: none;
                  homogeneous: true;
                  column-spacing: 8;
                  row-spacing: 8;
                  min-children-per-line: 2;
                  max-children-per-line: 4;
                }
              }

              /* Flatpaks Section */
              Box flatpaks_section {
                orientation: vertical;
                spacing: 8;
                visible: false;

                Label {
                  label: "Flatpaks";
                  xalign: 0.0;
                  margin-start: 4;

                  styles ["title-2"]
                }

                FlowBox flatpaks_flow {
                  selection-mode: none;
                  homogeneous: true;
                  column-spacing: 8;
                  row-spacing: 8;
                  min-children-per-line: 2;
                  max-children-per-line: 4;
                }
              }
            };
          };
        };
      }
    }

    Separator {}

    ActionBar {
      revealed: true;

      [start]
      Button remove_all_button {
        label: "Remove All";
        tooltip-text: "Remove all installed packages from this Brewfile";

        styles ["destructive-action"]
      }

      [end]
      Button install_all_button {
        label: "Install All";
        tooltip-text: "Install all packages from this Brewfile";

        styles ["suggested-action"]
      }
    }
  };
}
