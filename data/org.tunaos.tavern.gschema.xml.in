<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="tavern">
  <schema id="@APPLICATION_ID@" path="/@APPLICATION_ID_PATH@/">
    <key name="window-width" type="i">
      <default>1100</default>
      <summary>Window width</summary>
    </key>
    <key name="window-height" type="i">
      <default>750</default>
      <summary>Window height</summary>
    </key>
    <key name="window-maximized" type="b">
      <default>false</default>
      <summary>Window maximized state</summary>
    </key>
    <key name="outdated-check-enabled" type="b">
      <default>true</default>
      <summary>Enable automatic outdated package checks</summary>
      <description>When enabled, Tavern will check for outdated homebrew packages on startup and periodically in the background</description>
    </key>
    <key name="outdated-check-interval-hours" type="i">
      <default>24</default>
      <summary>Interval in hours for checking outdated packages</summary>
      <description>Minimum time between consecutive background checks for outdated packages</description>
      <range min="1" max="168"/>
    </key>
  </schema>
</schemalist>
