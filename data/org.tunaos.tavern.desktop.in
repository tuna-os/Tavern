[Desktop Entry]
Name=Tavern
Comment=Browse and install Homebrew packages
Exec=tavern %U
Icon=@APPLICATION_ID@
Terminal=false
Type=Application
Categories=System;PackageManager;
Keywords=homebrew;brew;package;install;software;
StartupNotify=true
DBusActivatable=true
MimeType=text/x-brewfile;application/x-brewfile;x-scheme-handler/brew;x-scheme-handler/homebrew;
