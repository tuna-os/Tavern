<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>@APPLICATION_ID@</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <name>Tavern</name>
  <summary>Browse and install Homebrew packages</summary>
  <description>
    <p>
      Tavern is a graphical app store for Homebrew, letting you browse, search,
      install, and remove both formulae and casks with a beautiful GNOME interface.
    </p>
  </description>
  <url type="homepage">https://github.com/hanthor/tavern</url>
  <content_rating type="oars-1.1" />
  <releases>
    <release version="0.1.0" date="2026-02-28">
      <description>
        <p>Initial release.</p>
      </description>
    </release>
  </releases>
  <branding>
    <color type="primary" scheme_preference="light">#b5deff</color>
    <color type="primary" scheme_preference="dark">#1a5fb4</color>
  </branding>
</component>
